# Neon Postgres connection string (wiki index + plans + rate limits + showcase runs)
DATABASE_URL=

# Vercel AI Gateway key — chat model, embeddings, and reranker all route through it
AI_GATEWAY_API_KEY=

# Browserbase — enables the live-data tier (live_search/live_fetch) and the
# browser showcase (run_showcase). Both tiers stay unregistered without a key.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Optional overrides
# AI_MODEL=anthropic/claude-haiku-4.5
# RERANK_MODEL=voyage/rerank-2.5-lite
# SHOWCASE_MODEL=anthropic/claude-haiku-4.5

# Ops
# NAVIGATOR_DISABLED=1   # kill switch: pause the chat endpoint
# LIVE_DISABLED=1        # pause only the live-web tier
# SHOWCASE_DISABLED=1    # pause only browser demos
